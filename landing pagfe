<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CA Tushar Saraf | Capital Markets & Investment Banking</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #B8974A;
    --gold-light: #D4B06A;
    --gold-dim: #8C7038;
    --cream: #F9F6F0;
    --ink: #1A1714;
    --ink-mid: #3D3830;
    --ink-soft: #6B6357;
    --ink-muted: #9C9288;
    --rule: rgba(184,151,74,0.22);
    --rule-light: rgba(184,151,74,0.10);
    --white: #FFFFFF;
    --card-bg: rgba(255,255,255,0.7);
    --card-border: rgba(184,151,74,0.18);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background-color: var(--cream);
    color: var(--ink);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 3rem;
    background: rgba(249,246,240,0.88);
    backdrop-filter: blur(14px);
    border-bottom: 0.5px solid var(--rule);
  }

  .nav-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-transform: uppercase;
    text-decoration: none;
  }

  .nav-brand span { color: var(--gold); }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--gold); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 7rem 3rem 4rem;
    max-width: 1280px;
    margin: 0 auto;
    gap: 4rem;
    position: relative;
  }

  .hero-left { position: relative; z-index: 1; }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 2rem;
    height: 0.5px;
    background: var(--gold);
  }

  .hero-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 5.5vw, 5.2rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .hero-name em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ink-soft);
    letter-spacing: 0.03em;
    margin-bottom: 2rem;
    font-style: italic;
  }

  .hero-desc {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--ink-soft);
    max-width: 440px;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: var(--ink);
    color: var(--cream);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    transition: background 0.25s, transform 0.15s;
    border: none;
    cursor: pointer;
  }

  .btn-primary:hover { background: var(--gold-dim); transform: translateY(-1px); }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: transparent;
    color: var(--ink);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    border: 0.5px solid var(--ink);
    transition: all 0.25s;
    cursor: pointer;
  }

  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

  /* ── HERO RIGHT / PHOTO ── */
  .hero-right {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .photo-frame {
    position: relative;
    width: 380px;
    height: 480px;
  }

  .photo-frame::before {
    content: '';
    position: absolute;
    top: -16px; left: -16px;
    width: 100%; height: 100%;
    border: 0.5px solid var(--gold);
    z-index: 0;
  }

  .photo-frame::after {
    content: '';
    position: absolute;
    bottom: -16px; right: -16px;
    width: 55%; height: 55%;
    border: 0.5px solid var(--gold-dim);
    z-index: 0;
  }

  .photo-frame img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    filter: grayscale(8%);
  }

  .photo-badge {
    position: absolute;
    bottom: -2rem;
    left: -2.5rem;
    z-index: 2;
    background: var(--ink);
    padding: 1rem 1.4rem;
    border-left: 2px solid var(--gold);
    color: var(--cream);
  }

  .photo-badge .badge-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    line-height: 1;
    color: var(--gold-light);
  }

  .photo-badge .badge-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(249,246,240,0.55);
    margin-top: 0.2rem;
  }

  /* ── SECTION COMMONS ── */
  section {
    position: relative;
    z-index: 1;
  }

  .section-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 6rem 3rem;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 0.5px;
    background: var(--gold);
  }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .section-heading em { font-style: italic; color: var(--gold); }

  .section-sub {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.75;
    font-weight: 300;
    max-width: 540px;
    margin-bottom: 3.5rem;
  }

  /* ── STATS STRIP ── */
  .stats-strip {
    background: var(--ink);
    padding: 0;
  }

  .stats-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3.5rem 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .stat-item {
    text-align: center;
    padding: 1.5rem 2rem;
    border-right: 0.5px solid rgba(184,151,74,0.2);
  }

  .stat-item:last-child { border-right: none; }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.2rem;
    font-weight: 300;
    color: var(--gold-light);
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .stat-label {
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(249,246,240,0.45);
  }

  /* ── EXPERTISE ── */
  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: var(--rule);
    border: 0.5px solid var(--rule);
  }

  .expertise-card {
    background: var(--cream);
    padding: 2.5rem 2rem;
    transition: background 0.25s;
    cursor: default;
  }

  .expertise-card:hover { background: var(--white); }

  .expertise-icon {
    width: 2.5rem;
    height: 2.5rem;
    margin-bottom: 1.25rem;
    opacity: 0.75;
  }

  .expertise-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.7rem;
    letter-spacing: 0.01em;
  }

  .expertise-card p {
    font-size: 0.84rem;
    color: var(--ink-soft);
    line-height: 1.75;
    font-weight: 300;
  }

  .expertise-tag {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-dim);
    font-weight: 500;
  }

  /* ── ABOUT ── */
  .about-wrap {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 6rem;
    align-items: start;
  }

  .about-left {}

  .about-right p {
    font-size: 0.92rem;
    line-height: 1.9;
    color: var(--ink-soft);
    font-weight: 300;
    margin-bottom: 1.25rem;
  }

  .about-right p:last-child { margin-bottom: 0; }

  .about-right strong {
    color: var(--ink);
    font-weight: 500;
  }

  .credentials-list {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .credential-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .credential-bullet {
    flex-shrink: 0;
    width: 0.35rem;
    height: 0.35rem;
    background: var(--gold);
    border-radius: 50%;
    position: relative;
    top: -0.1em;
  }

  .credential-text {
    font-size: 0.84rem;
    color: var(--ink-soft);
    line-height: 1.5;
    font-weight: 300;
  }

  .credential-text strong {
    color: var(--ink);
    font-weight: 500;
  }

  /* ── SERVICES / WHAT I DO ── */
  .services-section { background: var(--white); }

  .services-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--rule-light);
    border: 0.5px solid var(--rule-light);
  }

  .service-item {
    background: var(--white);
    padding: 2.5rem 2.5rem;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    transition: background 0.2s;
  }

  .service-item:hover { background: var(--cream); }

  .service-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    color: var(--rule);
    line-height: 0.9;
    flex-shrink: 0;
    letter-spacing: -0.03em;
  }

  .service-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .service-content p {
    font-size: 0.82rem;
    color: var(--ink-soft);
    line-height: 1.75;
    font-weight: 300;
  }

  /* ── CONNECT ── */
  .connect-section {
    background: var(--ink);
    text-align: center;
  }

  .connect-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 7rem 3rem;
  }

  .connect-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .connect-label::before, .connect-label::after {
    content: '';
    display: block;
    width: 1.5rem;
    height: 0.5px;
    background: var(--gold-dim);
  }

  .connect-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 300;
    color: var(--cream);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .connect-heading em { font-style: italic; color: var(--gold-light); }

  .connect-sub {
    font-size: 0.9rem;
    color: rgba(249,246,240,0.45);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 2.5rem;
  }

  .connect-email {
    display: inline-block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--gold-light);
    text-decoration: none;
    border-bottom: 0.5px solid var(--gold-dim);
    padding-bottom: 0.2rem;
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .connect-email:hover { color: var(--cream); }

  /* ── SOCIAL ── */
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1.5rem;
    border: 0.5px solid rgba(184,151,74,0.3);
    color: rgba(249,246,240,0.55);
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: all 0.25s;
    font-weight: 400;
  }

  .social-link:hover {
    border-color: var(--gold);
    color: var(--gold-light);
    background: rgba(184,151,74,0.06);
  }

  .social-link svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  /* ── FOOTER ── */
  footer {
    background: #110F0D;
    padding: 1.75rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 0.5px solid rgba(184,151,74,0.08);
  }

  .footer-copy {
    font-size: 0.72rem;
    color: rgba(249,246,240,0.2);
    letter-spacing: 0.08em;
  }

  .footer-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    color: var(--gold-dim);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ── DIVIDER ── */
  .ornament {
    text-align: center;
    color: var(--gold-dim);
    font-size: 1rem;
    letter-spacing: 0.5em;
    padding: 0 3rem 1rem;
    opacity: 0.5;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate {
    opacity: 0;
    animation: fadeUp 0.75s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .delay-1 { animation-delay: 0.15s; }
  .delay-2 { animation-delay: 0.3s; }
  .delay-3 { animation-delay: 0.45s; }
  .delay-4 { animation-delay: 0.6s; }
  .delay-5 { animation-delay: 0.75s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }

    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 6rem 1.5rem 3rem;
      gap: 3rem;
    }

    .hero-desc { margin-left: auto; margin-right: auto; }
    .hero-ctas { justify-content: center; }
    .hero-eyebrow { justify-content: center; }

    .photo-frame {
      width: 280px;
      height: 360px;
    }

    .photo-badge {
      left: 0;
      bottom: -1.5rem;
    }

    .stats-inner {
      grid-template-columns: 1fr 1fr;
      padding: 2.5rem 1.5rem;
    }

    .stat-item:nth-child(2) { border-right: none; }
    .stat-item:nth-child(3) { border-top: 0.5px solid rgba(184,151,74,0.2); }
    .stat-item:nth-child(4) { border-right: none; border-top: 0.5px solid rgba(184,151,74,0.2); }

    .section-inner { padding: 4rem 1.5rem; }

    .expertise-grid { grid-template-columns: 1fr; }

    .about-wrap { grid-template-columns: 1fr; gap: 3rem; }

    .services-list { grid-template-columns: 1fr; }

    .connect-inner { padding: 5rem 1.5rem; }

    footer {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
      padding: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .hero-name { font-size: 2.6rem; }
    .photo-frame { width: 240px; height: 300px; }
    .social-links { gap: 0.75rem; }
    .social-link { padding: 0.6rem 1rem; font-size: 0.65rem; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-brand">CA Tushar <span>Saraf</span></a>
  <ul class="nav-links">
    <li><a href="#expertise">Expertise</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>

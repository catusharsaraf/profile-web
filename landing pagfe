<script>
  // Intersection Observer for scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        entry.target.style.transition = 'opacity 0.75s cubic-bezier(0.16,1,0.3,1), transform 0.75s cubic-bezier(0.16,1,0.3,1)';
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.expertise-card, .service-item, .credential-item').forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(24px)';
    el.style.transitionDelay = `${i * 0.06}s`;
    observer.observe(el);
  });

  // Photo fallback — show initials if image fails
  const img = document.querySelector('.photo-frame img');
  if (img) {
    img.onerror = function() {
      const frame = this.parentElement;
      this.remove();
      const placeholder = document.createElement('div');
      placeholder.style.cssText = `
        width: 100%; height: 100%;
        background: linear-gradient(135deg, #2a2520 0%, #1a1714 100%);
        display: flex; align-items: center; justify-content: center;
        position: relative; z-index: 1;
      `;
      placeholder.innerHTML = `<span style="font-family:'Cormorant Garamond',serif; font-size:5rem; font-weight:300; color:#B8974A; letter-spacing:0.1em;">TS</span>`;
      frame.insertBefore(placeholder, frame.firstChild);
    };
  }
</script>
